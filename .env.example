# ── Database ──────────────────────────────────────────────────
DB_NAME=oh_my_opensource
DB_USER=admin
DB_PASSWORD=

# ── GitHub OAuth App ───────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub API ─────────────────────────────────────────────────
GITHUB_TOKEN=

# ── AI API ─────────────────────────────────────────────────────
GLM_API_KEY=
GEMINI_API_KEY=

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=

# ── OAuth2 리다이렉트 (프로덕션 도메인으로 변경) ───────────────────
OAUTH2_REDIRECT_URI=https://도메인.com/oauth/callback

# ── 프론트엔드 빌드 시 사용 (브라우저에서 백엔드를 가리키는 공개 URL) ──
NEXT_PUBLIC_API_URL=https://api.도메인.com
